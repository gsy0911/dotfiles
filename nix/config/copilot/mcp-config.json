{
  "mcpServers": {
    "serena": {
      "type": "local",
      "command": "uvx",
      "tools": [
        "*"
      ],
      "args": [
        "--from",
	"git+https://github.com/oraios/serena",
	"serena-mcp-server",
	"--context",
	"claude-code",
	"--project",
	"."
      ]
    },
    "fetch-mcp": {
      "type": "local",
      "command": "npx",
      "tools": [
        "*"
      ],
      "args": [
        "mcp-fetch-server"
      ]
    },
    "playwright": {
      "type": "local",
      "command": "npx",
      "tools": [
        "*"
      ],
      "args": ["@playwright/mcp@latest"]
    },
    "figma": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "chrome-devtools": {
      "type": "local",
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    }
  }
}

